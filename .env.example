# ─────────────────────────────────────────────────────────────────────
# Penny PWA — Environment Variables
# ─────────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` — it's already in .gitignore.
# In production, set these in Vercel: https://vercel.com/<org>/<project>/settings/environment-variables
# ─────────────────────────────────────────────────────────────────────

# ─── Anthropic ───────────────────────────────────────────────────────
# Get one: https://console.anthropic.com/settings/keys
# Server-side only. Never prefix with VITE_ or it leaks to the browser.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Default model for Penny. Override per-request if needed.
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ─── Stripe ──────────────────────────────────────────────────────────
# Get keys: https://dashboard.stripe.com/apikeys
# Use TEST keys (sk_test_*) until you're ready to charge real money.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs from your Stripe dashboard. Create three products:
#   - Penny Pro Monthly      → ~$9-12/mo
#   - Penny Pro Yearly       → ~$99-120/yr
#   - Penny Premium Monthly  → ~$24-39/mo
#   - Penny Premium Yearly   → ~$240-399/yr
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_PREMIUM_MONTHLY=price_...
STRIPE_PRICE_PREMIUM_YEARLY=price_...

# Public Stripe key — safe to expose to browser
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── App config ──────────────────────────────────────────────────────
# Used in Stripe redirects. Localhost in dev, real URL in prod.
APP_URL=http://localhost:3000

# Comma-separated CORS origins for your API routes (production: your real domain only)
ALLOWED_ORIGINS=http://localhost:3000

# ─── Optional: live data tools ───────────────────────────────────────
# For the FX/market-data tools. Leave blank to disable those tools.
# Free tier: https://exchangerate.host (no key needed) or https://www.exchangerate-api.com
EXCHANGE_RATE_API_KEY=

# ─── Optional: rate limiting ─────────────────────────────────────────
# Upstash Redis for IP-based rate limiting on /api/chat
# Free tier: https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
